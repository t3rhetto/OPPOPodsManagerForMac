<Window x:Class="OppoPodsWPF.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" ShowInTaskbar="False"
        Topmost="True" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        Background="Transparent">
    <Border Background="#E8202020" BorderBrush="#33FFFFFF" BorderThickness="1"
            CornerRadius="8" Padding="16,12" MinWidth="240"
            Effect="{DynamicResource DropShadow}">
        <StackPanel>
            <TextBlock x:Name="TitleBlock" Text="OPPO Pods" FontSize="13" FontWeight="SemiBold"
                       Foreground="White" Margin="0,0,0,10" HorizontalAlignment="Center"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <!-- Left -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock x:Name="LeftPct" Text="- %" FontSize="24" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LeftLabel" Text="左耳" FontSize="10" Foreground="#888"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
                <!-- Case -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock x:Name="CasePct" Text="- %" FontSize="24" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CaseLabel" Text="充电盒" FontSize="10" Foreground="#888"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
                <!-- Right -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock x:Name="RightPct" Text="- %" FontSize="24" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="RightLabel" Text="右耳" FontSize="10" Foreground="#888"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</Window>
