<ui:FluentWindow x:Class="OppoPodsWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="OPPO Pods For Windows" Height="640" Width="460"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏（v1.0.6: 原生 ComboBox 跟设置页一致） -->
        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
            <ComboBox x:Name="CbDevice" SelectionChanged="CbDevice_SelectionChanged"
                      Height="30" MinWidth="120" MaxWidth="240"
                      HorizontalAlignment="Left" VerticalAlignment="Center"
                      Margin="16,0,0,0" Padding="8,0"
                      FontSize="12" Cursor="Hand"
                      HorizontalContentAlignment="Left"
                      VerticalContentAlignment="Center"
                      ToolTip="切换当前操作的耳机">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DeviceName}" Padding="2,0"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Width="40" Height="28" Click="Close_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,4,0"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Cursor="Hand">
                <ui:SymbolIcon Symbol="Dismiss20" FontSize="14"/>
            </Button>
        </Grid>

        <!-- 主页面 -->
        <ScrollViewer x:Name="MainPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,4,16,12">

            <!-- Battery -->
            <Border Margin="0,0,0,8" Padding="16"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource ControlCornerRadius}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="电量" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"
                               HorizontalAlignment="Center"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="8,0">
                            <Image Source="/Assets/left.png" Height="64"/>
                            <TextBlock x:Name="LeftLabel" Text="-%" HorizontalAlignment="Center" FontSize="11"/>
                            <ProgressBar x:Name="LeftBar" Width="64" Height="6" Value="0" Maximum="100" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="8,0">
                            <Image Source="/Assets/cang.png" Height="64"/>
                            <TextBlock x:Name="CaseLabel" Text="-%" HorizontalAlignment="Center" FontSize="11"/>
                            <ProgressBar x:Name="CaseBar" Width="64" Height="6" Value="0" Maximum="100" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="8,0">
                            <Image Source="/Assets/right.png" Height="64"/>
                            <TextBlock x:Name="RightLabel" Text="-%" HorizontalAlignment="Center" FontSize="11"/>
                            <ProgressBar x:Name="RightBar" Width="64" Height="6" Value="0" Maximum="100" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    <!-- 佩戴状态 -->
                    <TextBlock x:Name="WearStatus" Text="" FontSize="11" HorizontalAlignment="Center"
                               Opacity="0.6" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- ANC -->
            <Border Margin="0,0,0,8" Padding="16"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource ControlCornerRadius}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="降噪控制" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"
                               HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnSmart" Content="降噪" Tag="Smart" Click="AncMain_Click"
                                Width="90" Height="28" Margin="0" BorderThickness="0" Padding="0"
                                Background="Transparent" FocusVisualStyle="{x:Null}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnAdaptive" Content="自适应" Tag="Adaptive" Click="AncMain_Click"
                                Width="90" Height="28" Margin="0" BorderThickness="0" Padding="0"
                                Background="Transparent" FocusVisualStyle="{x:Null}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnTrans" Content="通透" Tag="Transparency" Click="AncMain_Click"
                                Width="90" Height="28" Margin="0" BorderThickness="0" Padding="0"
                                Background="Transparent" FocusVisualStyle="{x:Null}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnOff" Content="关闭" Tag="Off" Click="AncMain_Click"
                                Width="90" Height="28" Margin="0" BorderThickness="0" Padding="0"
                                Background="Transparent" FocusVisualStyle="{x:Null}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <StackPanel x:Name="AncSub" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0" Visibility="Collapsed">
                        <Button x:Name="BtnAncSmart" Content="智能" Tag="Smart" Width="72" Click="AncSub_Click" Margin="2"
                                Background="Transparent" FocusVisualStyle="{x:Null}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnAncLight" Content="轻度" Tag="Light" Width="72" Click="AncSub_Click" Margin="2"
                                Background="Transparent" FocusVisualStyle="{x:Null}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnAncMedium" Content="中度" Tag="Medium" Width="72" Click="AncSub_Click" Margin="2"
                                Background="Transparent" FocusVisualStyle="{x:Null}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnAncDeep" Content="深度" Tag="Deep" Width="72" Click="AncSub_Click" Margin="2"
                                Background="Transparent" FocusVisualStyle="{x:Null}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Spatial Audio (Enco X3 only) -->
            <Border x:Name="SpatialAudioPanel" Margin="0,0,0,8" Padding="16"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource ControlCornerRadius}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="空间音频" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"
                               HorizontalAlignment="Center"/>
                    <UniformGrid Columns="3">
                        <RadioButton Content="关闭" Tag="Off" GroupName="SpatialAudio" Margin="4" IsChecked="True"
                                     Checked="SpatialAudio_Changed"/>
                        <RadioButton Content="固定" Tag="Fixed" GroupName="SpatialAudio" Margin="4"
                                     Checked="SpatialAudio_Changed"/>
                        <RadioButton Content="头部追踪" Tag="Track" GroupName="SpatialAudio" Margin="4"
                                     Checked="SpatialAudio_Changed"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Features -->
            <Border Padding="16"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource ControlCornerRadius}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="功能" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"
                               HorizontalAlignment="Center"/>
                    <UniformGrid Columns="2">
                        <CheckBox x:Name="CbSpatial" Content="空间音效" Margin="4" HorizontalAlignment="Center"
                                  Checked="CbSpatial_Changed" Unchecked="CbSpatial_Changed" Visibility="Collapsed"/>
                        <CheckBox x:Name="CbGame" Content="游戏模式" Margin="4" HorizontalAlignment="Center"
                                  Checked="CbGame_Changed" Unchecked="CbGame_Changed"/>
                    </UniformGrid>
                    <CheckBox x:Name="CbDualDevice" Content="双设备连接" Margin="4" HorizontalAlignment="Center"
                              Checked="CbDualDevice_Changed" Unchecked="CbDualDevice_Changed" Visibility="Collapsed"/>

                    <TextBlock Text="大师调音" FontSize="12" Margin="0,6,0,2" HorizontalAlignment="Center"/>
                    <ComboBox x:Name="CbEq" SelectionChanged="CbEq_SelectionChanged" Height="30" Padding="8,0" Margin="0,0,0,6"/>
                </StackPanel>
            </Border>

            <!-- 设置 & 关于 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Button Height="36" FontSize="12" Opacity="0.7" Padding="12,0" Click="Settings_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Settings32" FontSize="16"/>
                        <TextBlock Text=" 设置" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Height="36" FontSize="12" Opacity="0.7" Padding="12,0" Click="About_Click" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Info20" FontSize="16"/>
                        <TextBlock Text=" 关于" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

        </StackPanel>
        </ScrollViewer>

        <!-- 设置页 -->
        <ScrollViewer x:Name="SettingsPanel" Grid.Row="1" VerticalScrollBarVisibility="Disabled" Visibility="Collapsed">
        <StackPanel Margin="16,4,16,12">

            <Border Padding="16"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource ControlCornerRadius}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="设置" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="设备型号" FontSize="12" Margin="0,0,0,2" HorizontalAlignment="Center"/>
                    <ComboBox x:Name="CbBrand" SelectionChanged="CbBrand_Changed" Height="30" Padding="8,0" Margin="0,0,0,4"
                              IsEditable="False" IsTextSearchEnabled="True"/>
                    <ComboBox x:Name="CbSeries" SelectionChanged="CbSeries_Changed" Height="30" Padding="8,0" Margin="0,0,0,4"
                              IsEditable="False" IsTextSearchEnabled="True"/>
                    <ComboBox x:Name="CbModel" SelectionChanged="CbModel_Changed" Height="30" Padding="8,0" Margin="0,0,0,12"
                              IsEditable="False" IsTextSearchEnabled="True"/>
                    <TextBlock x:Name="ModelNote" Text="" FontSize="10" HorizontalAlignment="Center" Opacity="0.5" Margin="0,-8,0,8"/>

                    <TextBlock Text="自定义设备名称" FontSize="12" Margin="0,0,0,2" HorizontalAlignment="Center"/>
                    <TextBox x:Name="TbCustomName" TextChanged="TbCustomName_Changed" Height="30" Padding="8,4" Margin="0,0,0,12"
                             HorizontalContentAlignment="Center"/>

                    <TextBlock Text="游戏模式实现" FontSize="12" Margin="0,0,0,2" HorizontalAlignment="Center"/>
                    <ComboBox x:Name="CbGameMode" SelectionChanged="CbGameMode_Changed" Height="30" Padding="8,0" Margin="0,0,0,12">
                        <ComboBoxItem Content="标准 (28)"/>
                        <ComboBoxItem Content="兼容 (28+06)"/>
                    </ComboBox>

                    <TextBlock Text="主题" FontSize="12" Margin="0,0,0,2" HorizontalAlignment="Center"/>
                    <ComboBox x:Name="CbTheme" SelectionChanged="CbTheme_Changed" Height="30" Padding="8,0" Margin="0,0,0,12">
                        <ComboBoxItem Content="跟随系统"/>
                        <ComboBoxItem Content="深色"/>
                        <ComboBoxItem Content="浅色"/>
                    </ComboBox>

                    <CheckBox x:Name="CbTray" Content="关闭到托盘：关闭窗口时最小化到系统托盘" Margin="0,0,0,8"
                              Checked="CbTray_Changed" Unchecked="CbTray_Changed"/>
                    <CheckBox x:Name="CbAuto" Content="开机自启：系统启动时自动运行" Margin="0,0,0,12"
                              Checked="CbAuto_Changed" Unchecked="CbAuto_Changed"/>
                </StackPanel>
            </Border>

            <!-- 返回 -->
            <Button Height="36" Margin="0,8,0,0"
                    HorizontalAlignment="Center" Click="Settings_Click"
                    FontSize="12" Opacity="0.7"
                    Padding="12,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowLeft20" FontSize="16"/>
                    <TextBlock Text=" 返回" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </StackPanel>
        </ScrollViewer>

        <!-- 关于页 -->
        <ScrollViewer x:Name="AboutPanel" Grid.Row="1" VerticalScrollBarVisibility="Disabled" Visibility="Collapsed">
        <StackPanel Margin="16,4,16,12">
            <Border Padding="16"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource ControlCornerRadius}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="关于" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="OPPO Pods For Windows" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="v1.0.6" FontSize="11" HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,12"/>
                    <TextBlock Text="致谢" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock FontSize="10" HorizontalAlignment="Center" Opacity="0.6" Margin="0,0,0,2">
                        <Hyperlink NavigateUri="https://github.com/Leaf-lsgtky/OppoPods" RequestNavigate="Hyperlink_RequestNavigate">
                            Leaf-lsgtky/OppoPods — OPPO 耳机私有协议逆向
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock FontSize="10" HorizontalAlignment="Center" Opacity="0.6" Margin="0,0,0,2">
                        <Hyperlink NavigateUri="https://github.com/1812z/OppoPods" RequestNavigate="Hyperlink_RequestNavigate">
                            1812z/OppoPods — 功能实现参考
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock FontSize="10" HorizontalAlignment="Center" Opacity="0.6" Margin="0,0,0,12">
                        <Hyperlink NavigateUri="https://github.com/lepoco/wpfui" RequestNavigate="Hyperlink_RequestNavigate">
                            lepoco/wpfui — Windows 11 风格 UI 框架
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Text="开源地址" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock FontSize="10" HorizontalAlignment="Center" Opacity="0.6">
                        <Hyperlink NavigateUri="https://github.com/Zhaoyi-ya/OPPO-Pods-For-Windows" RequestNavigate="Hyperlink_RequestNavigate">
                            github.com/Zhaoyi-ya/OPPO-Pods-For-Windows
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
            <Button Height="36" Margin="0,8,0,0" HorizontalAlignment="Center"
                    Click="About_Click" FontSize="12" Opacity="0.7" Padding="12,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowLeft20" FontSize="16"/>
                    <TextBlock Text=" 返回" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
        </ScrollViewer>

        <!-- 连接状态栏 -->
        <Border x:Name="StatusBar" Grid.Row="2" Padding="12,6"
                Background="#18202020" BorderBrush="#30FFFFFF" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#FF5555" Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText" Text="未连接" FontSize="11" Foreground="#FF8888"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="BtnReconnect" Content="重新连接" Height="24" FontSize="11"
                        HorizontalAlignment="Right" Click="Reconnect_Click"
                        Padding="12,0" Visibility="Collapsed"/>

            </Grid>
        </Border>

    </Grid>
</ui:FluentWindow>
