<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OppoPodsManager.ToastWindow"
        WindowDecorations="None" ShowInTaskbar="False"
        Topmost="True" CanResize="False"
        SizeToContent="Height" Width="320"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Opacity="0">
    <!-- 初始 Opacity=0 从第 0 帧生效；淡入过渡声明在此，避免代码里被动画化的 1->0 闪现 -->
    <Window.Transitions>
        <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.4" Easing="CubicEaseOut"/>
        </Transitions>
    </Window.Transitions>

    <!-- 外层留少量阴影空间（贴角）；半透明背景；滑入/滑出用 RenderTransform 过渡(GPU 合成) -->
    <Border x:Name="Card" Margin="6" CornerRadius="14"
            Background="#CC1C1C1E"
            BorderBrush="#26FFFFFF" BorderThickness="1"
            BoxShadow="0 4 16 0 #55000000"
            RenderTransform="translateX(28px)">
        <Border.Transitions>
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform"
                                               Duration="0:0:0.4"
                                               Easing="CubicEaseOut"/>
            </Transitions>
        </Border.Transitions>
        <Border.Styles>
            <!-- 电量数值 pill -->
            <Style Selector="Border.pill">
                <Setter Property="Background" Value="#1FFFFFFF"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="0,10"/>
            </Style>
        </Border.Styles>

        <Grid>
            <!-- ========== 电量面板 ========== -->
            <StackPanel x:Name="BatteryPanel" Margin="18,16" Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#4CD964" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleBlock" Text="OPPO Pods"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#F5FFFFFF" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid ColumnDefinitions="*,8,*,8,*">
                    <Border Grid.Column="0" Classes="pill">
                        <StackPanel HorizontalAlignment="Center" Spacing="3">
                            <TextBlock x:Name="LeftPct" Text="- %" FontSize="22" FontWeight="Bold"
                                       Foreground="#F5FFFFFF" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                                <TextBlock x:Name="LeftBolt" Text="⚡" FontSize="11" IsVisible="False"
                                           Foreground="#4CD964" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LeftLabel" Text="左耳" FontSize="11"
                                           Foreground="#99FFFFFF" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Classes="pill">
                        <StackPanel HorizontalAlignment="Center" Spacing="3">
                            <TextBlock x:Name="CasePct" Text="- %" FontSize="22" FontWeight="Bold"
                                       Foreground="#F5FFFFFF" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                                <TextBlock x:Name="CaseBolt" Text="⚡" FontSize="11" IsVisible="False"
                                           Foreground="#4CD964" VerticalAlignment="Center"/>
                                <TextBlock x:Name="CaseLabel" Text="充电盒" FontSize="11"
                                           Foreground="#99FFFFFF" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Classes="pill">
                        <StackPanel HorizontalAlignment="Center" Spacing="3">
                            <TextBlock x:Name="RightPct" Text="- %" FontSize="22" FontWeight="Bold"
                                       Foreground="#F5FFFFFF" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                                <TextBlock x:Name="RightBolt" Text="⚡" FontSize="11" IsVisible="False"
                                           Foreground="#4CD964" VerticalAlignment="Center"/>
                                <TextBlock x:Name="RightLabel" Text="右耳" FontSize="11"
                                           Foreground="#99FFFFFF" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- ========== 低电量遮罩 ========== -->
            <Border x:Name="LowBatteryOverlay" Background="#CC1C1C1E" CornerRadius="14"
                    IsVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6" Margin="18,20">
                    <TextBlock Text="⚡ 低电量" FontSize="22" FontWeight="Bold"
                               Foreground="#FFB020" HorizontalAlignment="Center"/>
                    <TextBlock Text="建议尽快充电" FontSize="12"
                               Foreground="#99FFFFFF" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ========== 极低电量遮罩 ========== -->
            <Border x:Name="CriticalBatteryOverlay" Background="#CC1C1C1E" CornerRadius="14"
                    IsVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6" Margin="18,20">
                    <TextBlock Text="⚡ 电量极低" FontSize="22" FontWeight="Bold"
                               Foreground="#FF453A" HorizontalAlignment="Center"/>
                    <TextBlock Text="请立即充电" FontSize="12"
                               Foreground="#FF8078" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ========== 断开面板 ========== -->
            <StackPanel x:Name="DisconnectPanel" IsVisible="False" Margin="18,18" Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#FF453A" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DisconnectTitle" Text="" FontSize="14" FontWeight="SemiBold"
                               Foreground="#F5FFFFFF" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="连接已断开" FontSize="16" FontWeight="Bold"
                           Foreground="#FF8078" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
